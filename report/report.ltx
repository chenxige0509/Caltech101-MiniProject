\title{A Comparative Study of CNN and HOG Models for Caltech-101 Image Classification}
\author{Chenxi Ge \\ Harvard University \\ \href{mailto:steven_ge@fas.harvard.edu}{\texttt{steven\_ge@fas.harvard.edu}} \\ \url{https://github.com/chenxige0509/Caltech101-MiniProject}}
